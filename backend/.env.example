# Crazy Lister v3.0 — Environment Configuration
# Copy this file to .env and modify as needed

# Application
APP_NAME=Crazy Lister v3.0
DEBUG=false
API_V1_PREFIX=/api/v1

# Amazon SP-API
# Set to true for local testing with mock data
# Set to false to use real Amazon SP-API credentials
USE_AMAZON_MOCK=true

# Logging
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# CORS (localhost only for desktop app)
# CORS_ORIGINS=["*"]  (default in code)
