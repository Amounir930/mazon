# Crazy Lister v3.0 — Production Environment Configuration
# ============================================================
# Instructions:
# 1. Copy this file to .env
# 2. Fill in your Amazon SP-API credentials below
# 3. Save and restart Crazy Lister

# Application
APP_NAME=Crazy Lister v3.0
DEBUG=false
API_V1_PREFIX=/api/v1

# Amazon SP-API (Production)
# Get these from Amazon Developer Console:
# https://developer.amazonservices.com
SP_API_CLIENT_ID=amzn1.application-oa2-client.xxxxx
SP_API_CLIENT_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_SELLER_ROLE_ARN=arn:aws:iam::xxxxx:role/CrazyListerRole

# Qwen AI (Optional) - AI Product Generation
# Get API key from: https://portal.qwen.ai
QWEN_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
