# Crazy Lister v3.0 — Environment Configuration
# Real Amazon SP-API credentials required

# Application
APP_NAME=Crazy Lister v3.0
DEBUG=false
API_V1_PREFIX=/api/v1

# Amazon SP-API (Real Production)
# Get these from Amazon Developer Console
SP_API_CLIENT_ID=amzn1.application-oa2-client.xxxxx
SP_API_CLIENT_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_SELLER_ROLE_ARN=arn:aws:iam::xxxxx:role/CrazyListerRole

# Logging
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
