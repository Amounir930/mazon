# Crazy Lister API - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ==========================================
# Application Settings
# ==========================================
APP_NAME=Crazy Lister API
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ==========================================
# Database Configuration
# ==========================================
# For local development with SQLite (easier)
DATABASE_URL=sqlite:///./crazy_lister.db

# For production with PostgreSQL (recommended)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/crazy_lister

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ==========================================
# Redis & Celery Configuration
# ==========================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==========================================
# Amazon SP-API Configuration
# ==========================================
# Get these from Amazon Developer Console
# https://developer.amazonservices.com/
SP_API_CLIENT_ID=amzn1.application-oa2-client.your_client_id
SP_API_CLIENT_SECRET=your_sp_api_client_secret
SP_API_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# AWS IAM Credentials
# Get these from AWS Console > IAM > Users
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-west-1
AWS_SELLER_ROLE_ARN=arn:aws:iam::123456789012:role/YourSellingPartnerRole

# Default Amazon Marketplace
# Examples:
#   Egypt: ARBP9OOSHTCHU
#   US: ATVPDKIKX0DER
#   UK: A1F83G8C2ARO7P
#   Germany: A1PA6795UKMFR9
#   Japan: A1VC38T7YXB528
DEFAULT_MARKETPLACE_ID=ARBP9OOSHTCHU
DEFAULT_REGION=EU

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/crazy_lister.log
LOG_ROTATION=500 MB
LOG_RETENTION=30 days

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# CORS Origins (comma-separated)
# ==========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
